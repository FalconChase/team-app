rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        (request.auth.uid == userId ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'owner', 'manager', 'supervisor']);
    }

    match /teams/{teamId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'owner', 'manager', 'supervisor'];
    }

    match /teamLogs/{logId} {
      allow write: if request.auth != null;
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'owner', 'manager', 'supervisor'];
    }

    // App-wide settings (logo, etc.) — admin-tier write, authenticated read
    match /appSettings/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'owner', 'manager', 'supervisor'];
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }

  }
}