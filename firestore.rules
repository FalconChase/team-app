rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        (request.auth.uid == userId ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'owner', 'manager', 'supervisor']);
    }
    match /teams/{teamId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'owner', 'manager', 'supervisor'];
      // Projects subcollection
      match /projects/{projectId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'owner', 'manager', 'supervisor'];
      }
      // Weather log snapshots subcollection
      match /weatherLogs/{logId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }
    }
    match /teamLogs/{logId} {
      allow write: if request.auth != null;
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'owner', 'manager', 'supervisor'];
    }
    // App-wide settings (logo, etc.) — admin-tier write, authenticated read
    match /appSettings/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'owner', 'manager', 'supervisor'];
    }
    // Papers (documents tab)
    match /papers/{paperId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'owner', 'manager', 'supervisor'];
    }
    // Archive
    match /archive/{archiveId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'owner', 'manager', 'supervisor'];
    }
    // Records
    match /records/{recordId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'owner', 'manager', 'supervisor'];
    }
    // Member files
    match /memberFiles/{fileId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    // Announcements — anyone authenticated can post
    match /announcements/{announcementId} {
      allow read, write: if request.auth != null;
    }
    // Group Chat messages
    match /messages/{messageId} {
      allow read, write: if request.auth != null;
    }
    // Reminders — per user
    match /reminders/{reminderId} {
      allow read, write: if request.auth != null;
    }
    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}